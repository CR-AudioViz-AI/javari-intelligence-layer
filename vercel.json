{
  "version": 2,
  "name": "javari-intelligence-layer",
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "github": {
    "autoAlias": false
  },
  "crons": [
    {
      "path": "/api/cron/web-crawl",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron/sync-documents",
      "schedule": "*/15 * * * *"
    }
  ]
}